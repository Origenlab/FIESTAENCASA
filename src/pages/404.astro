---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Pagina No Encontrada | Fiesta en Casa"
  description="La pagina que buscas no existe."
>

  <section class="category-hero">
    <div class="category-hero__bg"></div>
    <div class="category-hero__container" style="text-align:center;padding:4rem 1.5rem;">
      <h1 class="category-hero__title">Pagina No Encontrada</h1>
      <p class="category-hero__subtitle" style="margin-top:1rem;">Lo sentimos, la pagina que buscas no existe o ha sido movida.</p>
      <a href="/" class="btn btn--primary btn--lg" style="margin-top:2rem;display:inline-block;">Volver al Inicio</a>
    </div>
  </section>

</Layout>
